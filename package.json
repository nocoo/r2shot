{
  "name": "r2shot",
  "version": "1.2.1",
  "private": true,
  "description": "Chrome extension to capture screenshots and upload to Cloudflare R2",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "tsc --noEmit && vite build",
    "build:dev": "tsc --noEmit && vite build --mode development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "build:zip": "bash scripts/build.sh",
    "prepare": "git config core.hookspath .husky",
    "release": "bun run scripts/release.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "tailwindcss": "4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1092.0",
    "brace-expansion": "^5.0.7",
    "clsx": "^2.1.1",
    "lucide-react": "1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tailwind-merge": "^3.6.0",
    "ws": "8.21.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "overrides": {
    "ws": "^8.21.1",
    "esbuild": "^0.28.1",
    "vite": "^8.1.5",
    "brace-expansion": "^5.0.7"
  }
}
